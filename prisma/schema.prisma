generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cosecha {
  id                   Int                   @id @default(autoincrement())
  fecha                DateTime
  kilosCosechados      Float
  cantidadCosechadores Int
  lotes                String
  totalHectareas       Float
  tipoCosecha          String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  cosechaLotes         CosechaLote[]
  procesos             ProcesoTrazabilidad[]
}

model Lote {
  id           Int           @id @default(autoincrement())
  codigo       String        @unique
  nombre       String?
  hectareas    Float?
  ubicacion    String?
  observacion  String?
  activo       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  cosechaLotes CosechaLote[]
}

model CosechaLote {
  id        Int      @id @default(autoincrement())
  cosechaId Int
  loteId    Int
  createdAt DateTime @default(now())
  cosecha   Cosecha  @relation(fields: [cosechaId], references: [id], onDelete: Cascade)
  lote      Lote     @relation(fields: [loteId], references: [id])

  @@unique([cosechaId, loteId])
}

model ProcesoTrazabilidad {
  id               Int      @id @default(autoincrement())
  fecha            DateTime
  etapa            String
  kilosIngresados  Float
  kilosResultantes Float
  porcentajeMerma  Float
  cosechaId        Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  cosecha          Cosecha  @relation(fields: [cosechaId], references: [id], onDelete: Cascade)
}
